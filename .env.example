# === CẤU HÌNH ZALO OA ===
# Hướng dẫn lấy token và user_id:
# 1. Tạo Zalo OA tại https://oa.zalo.me
# 2. Vào Cài đặt OA → Quản lý API → Tạo ứng dụng
# 3. Lấy App ID và App Secret, dùng API để lấy access_token
# 4. Follow OA bằng Zalo cá nhân của bạn
# 5. Gửi tin nhắn vào OA, webhook sẽ ghi lại user_id của bạn

ZALO_OA_TOKEN=your_access_token_here
ZALO_USER_ID=your_user_id_here

# === VÍ DỤ ===
# ZALO_OA_TOKEN=gAAAAABn...
# ZALO_USER_ID=123456789

# === CẤU HÌNH TELEGRAM BOT ===
# Hướng dẫn lấy token và chat_id:
# 1. Chat với @BotFather trên Telegram, gõ /newbot
# 2. Đặt tên bot và username (phải kết thúc bằng "bot")
# 3. Lấy BOT_TOKEN từ BotFather
# 4. Chat với bot mới tạo, gửi tin nhắn bất kỳ
# 5. Truy cập: https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
# 6. Tìm chat_id trong JSON trả về (số dạng: 123456789)

TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789
